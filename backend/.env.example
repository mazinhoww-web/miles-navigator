# ─── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://milesradar:mudesuasenha123@postgres:5432/milesradar
POSTGRES_PASSWORD=mudesuasenha123

# ─── Evolution API (WhatsApp) ─────────────────────────────────────────────────
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=minha-chave-secreta-evolution-2026
EVOLUTION_INSTANCE_NAME=milesradar

# ─── Alertas ─────────────────────────────────────────────────────────────────
# Número(s) WhatsApp para receber alertas — formato: 55 + DDD + número
# Múltiplos números: separar por vírgula (sem espaços)
ALERT_NUMBERS=5565999999999
MIN_BONUS_PCT=40
MAX_CPM=20.0
PROGRAMS_WATCH=
SILENT_START_HOUR=23
SILENT_END_HOUR=7

# ─── Bootstrap histórico ─────────────────────────────────────────────────────
BOOTSTRAP_MONTHS=36
BOOTSTRAP_DELAY_SECONDS=3

# ─── Parser LLM (opcional — melhora extração de posts ambíguos) ──────────────
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=
LLM_CONFIDENCE_THRESHOLD=0.7
LLM_ENABLED=true

# ─── Playwright (proxy para evitar bloqueios — opcional) ─────────────────────
USE_PROXY=false
PROXY_URL=

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=prod
LOG_LEVEL=INFO
