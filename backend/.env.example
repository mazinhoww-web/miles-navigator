# ─── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/milesradar

# ─── Evolution API / WhatsApp ─────────────────────────────────────────────────
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE=milesradar

# ─── Alertas ──────────────────────────────────────────────────────────────────
ALERT_NUMBERS=5511999999999,5511888888888
MIN_BONUS_PCT=40
PROGRAMS_WATCH=LATAM Pass,Smiles,Azul Fidelidade
MAX_CPM=20.0
SILENT_START_HOUR=23
SILENT_END_HOUR=7

# ─── Scraping ─────────────────────────────────────────────────────────────────
BOOTSTRAP_MONTHS=36
BOOTSTRAP_DELAY_SECONDS=3.0
USE_PROXY=false
PROXY_URL=

# ─── Parser LLM (Fase 6) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
LLM_ENABLED=true
LLM_CONFIDENCE_THRESHOLD=0.7

# ─── Apify (scraping via cloud — configura Actor IDs no painel /apify) ────────
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx

# Actor IDs — obtidos em apify.com após criar/forkar os actors
# Blogs WordPress (usar apify/website-content-crawler — zero configuração)
APIFY_ACTOR_PASSAGEIRODEPRIMEIRA=apify/website-content-crawler
APIFY_ACTOR_MELHORESDESTINOS=apify/website-content-crawler
APIFY_ACTOR_MESTREDASMILHAS=apify/website-content-crawler
APIFY_ACTOR_PONTOSPRAVOAR=apify/website-content-crawler

# Programas oficiais (usar apify/playwright-scraper com proxy)
APIFY_ACTOR_SMILES=
APIFY_ACTOR_LATAMPASS=
APIFY_ACTOR_AZUL=
APIFY_ACTOR_LIVELO=
APIFY_ACTOR_ESFERA=

# Bancos (sites protegidos por Cloudflare — usar proxy residencial)
APIFY_ACTOR_ITAU_IUPP=
APIFY_ACTOR_NUBANK=
APIFY_ACTOR_C6=
APIFY_ACTOR_INTER=
APIFY_ACTOR_SICOOB=

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=prod
LOG_LEVEL=INFO
